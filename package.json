{
  "name": "@gacfox/iconfont-generator",
  "version": "1.0.0",
  "description": "A tool that converts SVG icons into web font formats (TTF, WOFF, WOFF2, EOT) and generates CSS/HTML preview files.",
  "type": "module",
  "main": "iconfont.js",
  "bin": {
    "iconfont-generator": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "lib/",
    "template/"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "iconfont",
    "svg",
    "font",
    "ttf",
    "woff",
    "woff2",
    "eot",
    "icon",
    "generator"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gacfox/iconfont-generator.git"
  },
  "bugs": {
    "url": "https://github.com/gacfox/iconfont-generator/issues"
  },
  "homepage": "https://github.com/gacfox/iconfont-generator#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "fs-extra": "^11.2.0",
    "svg2ttf": "^5.2.0",
    "svgicons2svgfont": "^15.0.1",
    "ttf2eot": "^3.1.0",
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^8.0.0"
  }
}